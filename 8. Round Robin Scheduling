#include <stdio.h>

int main()
{
    int i, n, time = 0, remain, tq;
    int at[10], bt[10], rt[10];
    int wt = 0, tat = 0, flag;

    printf("Total number of process in the system: ");
    scanf("%d", &n);

    remain = n;

    for(i = 0; i < n; i++)
    {
        printf("\nEnter the Arrival and Burst time of the Process[%d]\n", i + 1);

        printf("Arrival time is: ");
        scanf("%d", &at[i]);

        printf("Burst time is: ");
        scanf("%d", &bt[i]);

        rt[i] = bt[i];
    }

    printf("\nEnter the Time Quantum for the process: ");
    scanf("%d", &tq);

    printf("\nProcess No\tBurst Time\tTAT\tWaiting Time\n");

    for(time = 0, i = 0; remain != 0;)
    {
        flag = 0;

        if(rt[i] <= tq && rt[i] > 0)
        {
            time += rt[i];
            rt[i] = 0;
            flag = 1;
        }
        else if(rt[i] > 0)
        {
            rt[i] -= tq;
            time += tq;
        }

        if(flag == 1)
        {
            remain--;

            printf("Process No[%d]\t%d\t\t%d\t%d\n",
                   i + 1,
                   bt[i],
                   time - at[i],
                   time - at[i] - bt[i]);

            tat += time - at[i];
            wt += time - at[i] - bt[i];
        }

        if(i == n - 1)
            i = 0;
        else if(at[i + 1] <= time)
            i++;
        else
            i = 0;
    }

    printf("\nAverage Turn Around Time: %.2f\n", (float)tat / n);
    printf("Average Waiting Time: %.2f\n", (float)wt / n);

    return 0;
}


