#include <stdio.h>
#include <semaphore.h>

#define SIZE 5

sem_t empty, full, mutex;
int item = 0;
int buffer;

void producer()
{
    sem_wait(&empty);
    sem_wait(&mutex);

    item++;
    buffer = item;
    printf("Producer: Item %d produced.\n", buffer);

    sem_post(&mutex);
    sem_post(&full);
}

void consumer()
{
    sem_wait(&full);
    sem_wait(&mutex);

    printf("Consumer: Item %d consumed.\n\n", buffer);
    buffer = 0;

    sem_post(&mutex);
    sem_post(&empty);
}

int main()
{
    int i;

    sem_init(&empty, 0, SIZE);
    sem_init(&full, 0, 0);
    sem_init(&mutex, 0, 1);

    printf("Producer-Consumer Problem Using Semaphores\n\n");

    for(i = 0; i < 5; i++)
    {
        producer();
        consumer();
    }

    sem_destroy(&empty);
    sem_destroy(&full);
    sem_destroy(&mutex);

    return 0;
}


