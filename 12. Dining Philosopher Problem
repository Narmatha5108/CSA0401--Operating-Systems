#include <stdio.h>
#include <pthread.h>
#include <unistd.h>

#define N 5

pthread_mutex_t chopstick[N];

void *philosopher(void *num)
{
    int id = *(int *)num;
    int left = id;
    int right = (id + 1) % N;

    printf("Philosopher %d is Thinking\n", id);
    sleep(1);

    // Pick up left chopstick
    pthread_mutex_lock(&chopstick[left]);
    printf("Philosopher %d picked up Left Chopstick %d\n", id, left);

    // Pick up right chopstick
    pthread_mutex_lock(&chopstick[right]);
    printf("Philosopher %d picked up Right Chopstick %d\n", id, right);

    // Eat
    printf("Philosopher %d is Eating\n", id);
    sleep(2);

    // Put down chopsticks
    pthread_mutex_unlock(&chopstick[left]);
    pthread_mutex_unlock(&chopstick[right]);

    printf("Philosopher %d finished Eating and released chopsticks\n", id);

    return NULL;
}

int main()
{
    pthread_t thread[N];
    int id[N];

    // Initialize mutexes
    for (int i = 0; i < N; i++)
        pthread_mutex_init(&chopstick[i], NULL);

    // Create philosopher threads
    for (int i = 0; i < N; i++)
    {
        id[i] = i;
        pthread_create(&thread[i], NULL, philosopher, &id[i]);
    }

    // Wait for all threads
    for (int i = 0; i < N; i++)
        pthread_join(thread[i], NULL);

    // Destroy mutexes
    for (int i = 0; i < N; i++)
        pthread_mutex_destroy(&chopstick[i]);

    return 0;
}


