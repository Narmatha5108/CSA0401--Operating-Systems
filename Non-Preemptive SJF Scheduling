#include <stdio.h>

int main()
{
    int n, i, j;
    int at[20], bt[20], st[20], et[20];
    int wt[20], tat[20], p[20];
    int temp;
    float avgwt = 0, avgtat = 0;

    printf("Enter the number of processes: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++)
    {
        p[i] = i + 1;

        printf("Enter the arrival time and execution time for process %d\n", i + 1);
        scanf("%d%d", &at[i], &bt[i]);
    }

    // Sorting according to execution time (SJF)
    for(i = 0; i < n-1; i++)
    {
        for(j = i+1; j < n; j++)
        {
            if(bt[i] > bt[j])
            {
                temp = bt[i];
                bt[i] = bt[j];
                bt[j] = temp;

                temp = at[i];
                at[i] = at[j];
                at[j] = temp;

                temp = p[i];
                p[i] = p[j];
                p[j] = temp;
            }
        }
    }

    // Calculate start and end time
    st[0] = at[0];

    for(i = 0; i < n; i++)
    {
        if(i > 0)
        {
            st[i] = et[i-1];
        }

        et[i] = st[i] + bt[i];

        wt[i] = st[i] - at[i];

        tat[i] = et[i] - at[i];

        avgwt += wt[i];
        avgtat += tat[i];
    }

    printf("\nProcess | Arrival time | Execution time | Start time | End time | Waiting\n");

    for(i = 0; i < n; i++)
    {
        printf("p[%d]\t | %d\t\t | %d\t\t | %d\t\t | %d\t | %d\n",
        p[i], at[i], bt[i], st[i], et[i], wt[i]);
    }

    printf("\nAverage waiting time = %.6f\n", avgwt/n);
    printf("Average turnaround time = %.6f\n", avgtat/n);

    return 0;
}



